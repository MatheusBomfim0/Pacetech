algoritmo "Aumento De Salario"

var
Salario, aumento, total: real

inicio
Escreval ("Informe seu Salario: ")
Leia(Salario)
Escreval("")

aumento <- Salario * 0.3
total <- Salario *1.3

Escreval ("Você recebeu um aumento de", aumento, "R$")
Escreval ("Seu salário será", total, "R$")




fimalgoritmo
